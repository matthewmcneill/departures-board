@@ -0,0 +1,210 @@
+<!DOCTYPE html>
+<html lang="en">
+<head>
+    <meta charset="UTF-8">
+    <meta name="viewport" content="user-scalable=no, initial-scale=1, maximum-scale=1, minimum-scale=1, width=device-width">
+    <title>Departures Board | RSS Feeds Editor</title>
+    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
+    <style>
+        .feed-info {max-width:65%;}
+    </style>
+    <script>
+        (() => {
+        const themeMatcher = window.matchMedia('(prefers-color-scheme: dark)');
+        const applyTheme = () => { document.documentElement.setAttribute('data-bs-theme', themeMatcher.matches ? 'dark' : 'light'); };
+        applyTheme();
+        themeMatcher.addEventListener('change', applyTheme);
+        })();
+    </script>
+</head>
+<body class="bg-body-tertiary py-4">
+    <div style="width: min(90%, 500px); margin:0 auto; padding:0 10px;">
+        <div class="card shadow-sm">
+            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
+                <h5 class="mb-0">Edit RSS Feeds</h5>
+                <button class="btn btn-light btn-sm fw-bold" onclick="openModal()">+ Add Feed</button>
+            </div>
+            <div class="card-body p-0">
+                <ul class="list-group list-group-flush" id="feedList">
+                    <li class="list-group-item text-center text-muted py-4">Loading feeds...</li>
+                </ul>
+            </div>
+            <div class="card-footer py-3">
+                <div class="d-flex gap-2">
+                    <button class="btn btn-success flex-grow-1" onclick="saveToServer()" id="saveBtn">
+                        Save Changes
+                    </button>
+                    <a href="/" class="btn btn-secondary">Close</a>
+                </div>
+                <div id="saveStatus" class="form-text mt-2 d-none text-center"></div>
+            </div>
+        </div>
+    </div>
+
+    <div class="modal fade" id="feedModal" tabindex="-1" aria-labelledby="feedModalLabel" aria-hidden="true">
+        <div class="modal-dialog modal-dialog-centered" style="max-width: 90%; width: 400px; margin: 0 auto;">
+            <div class="modal-content">
+                <div class="modal-header">
+                    <h1 class="modal-title fs-5" id="feedModalLabel">Add/Edit Feed</h1>
+                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
+                </div>
+                <div class="modal-body">
+                    <form id="feedForm">
+                        <input type="hidden" id="editIndex" value="-1">
+                        <div class="mb-3">
+                            <label for="feedName" class="form-label">Feed Name</label>
+                            <input type="text" class="form-control" id="feedName" required placeholder="e.g. BBC News">
+                        </div>
+                        <div class="mb-3">
+                            <label for="feedUrl" class="form-label">RSS URL</label>
+                            <input type="url" class="form-control" id="feedUrl" required placeholder="https://...">
+                        </div>
+                    </form>
+                </div>
+                <div class="modal-footer">
+                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
+                    <button type="button" class="btn btn-primary" onclick="saveFeed()">Save Feed</button>
+                </div>
+            </div>
+        </div>
+    </div>
+    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
+    <script>
+        let feeds = [];
+        let feedModalInstance;
+
+        const feedList = document.getElementById('feedList');
+        const nameInput = document.getElementById('feedName');
+        const urlInput = document.getElementById('feedUrl');
+        const indexInput = document.getElementById('editIndex');
+        const saveStatus = document.getElementById('saveStatus');
+
+        document.addEventListener('DOMContentLoaded', () => {
+            feedModalInstance = new bootstrap.Modal(document.getElementById('feedModal'));
+            loadFeeds();
+        });
+
+        // Load feeds from board
+        async function loadFeeds() {
+            try {
+                const response = await fetch('rss.json');
+                if (!response.ok) throw new Error('Network error');
+                feeds = await response.json();
+            } catch (error) {
+                console.error('Error fetching feeds:', error);
+                feedList.innerHTML = `<li class="list-group-item text-danger text-center">Failed to load feeds from Departures Board.</li>`;
+                return;
+            }
+            renderFeeds();
+        }
+
+        function renderFeeds() {
+            if (feeds.length === 0) {
+                feedList.innerHTML = `<li class="list-group-item text-center text-muted">No feeds available. Add one!</li>`;
+                return;
+            }
+            feedList.innerHTML = '';
+            feeds.forEach((feed, index) => {
+                const li = document.createElement('li');
+                li.className = 'list-group-item d-flex justify-content-between align-items-center';
+
+                li.innerHTML = `
+                    <div class="feed-info text-truncate">
+                        <div class="fw-bold text-truncate">${feed.name}</div>
+                        <small class="text-muted text-truncate d-block">${feed.url}</small>
+                    </div>
+                    <div class="btn-group btn-group-sm" role="group">
+                        <button type="button" class="btn btn-outline-secondary" onclick="openModal(${index})">Edit</button>
+                        <button type="button" class="btn btn-outline-danger" onclick="deleteFeed(${index})">Del</button>
+                    </div>
+                `;
+                feedList.appendChild(li);
+            });
+        }
+
+        function openModal(index = -1) {
+            if (index > -1) {
+                // Edit Mode
+                document.getElementById('feedModalLabel').innerText = 'Edit Feed';
+                nameInput.value = feeds[index].name;
+                urlInput.value = feeds[index].url;
+                indexInput.value = index;
+            } else {
+                // Add Mode
+                document.getElementById('feedModalLabel').innerText = 'Add New Feed';
+                document.getElementById('feedForm').reset();
+                indexInput.value = -1;
+            }
+            feedModalInstance.show();
+        }
+
+        function saveFeed() {
+            if (!nameInput.value || !urlInput.value) {
+                alert("Please fill in both fields.");
+                return;
+            }
+
+            const newFeed = {
+                name: nameInput.value,
+                url: urlInput.value
+            };
+
+            const idx = parseInt(indexInput.value);
+            if (idx > -1) {
+                feeds[idx] = newFeed;
+            } else {
+                feeds.push(newFeed);
+            }
+
+            renderFeeds();
+            feedModalInstance.hide();
+        }
+
+        function deleteFeed(index) {
+            if (confirm(`Are you sure you want to delete "${feeds[index].name}"?`)) {
+                feeds.splice(index, 1);
+                renderFeeds();
+            }
+        }
+
+        async function saveToServer() {
+            const btn = document.getElementById('saveBtn');
+            btn.disabled = true;
+            btn.innerText = 'Saving...';
+            saveStatus.classList.add('d-none');
+
+            try {
+                const blob = new Blob(
+                    [JSON.stringify(feeds, null, 2)],
+                    { type: 'application/json' }
+                );
+
+                const formData = new FormData();
+                formData.append('file', blob, 'rss.json');
+
+                const response = await fetch('/upload', {
+                    method: 'POST',
+                    body: formData
+                });
+
+                if (response.ok) {
+                    showStatus('Successfully saved to the Departures Board','text-success');
+                } else {
+                    showStatus('Failed to save updated RSS feeds to the Departures Board','text-warning');
+                }
+            } catch (error) {
+                showStatus('Network error. Failed to save the updated RSS feeds to the Departures Board','text-warning');
+            } finally {
+                btn.disabled = false;
+                btn.innerText = 'Save Changes';
+            }
+        }
+
+        function showStatus(message, textClass) {
+            saveStatus.innerText = message;
+            saveStatus.className = `form-text mt-2 ${textClass}`;
+            setTimeout(() => { saveStatus.classList.add('d-none'); }, 4000);
+        }
+    </script>
+</body>
+</html>
