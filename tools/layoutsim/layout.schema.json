{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Departures Board Layout",
  "description": "Schema for display board layouts in the Departures Board project.",
  "type": "object",
  "required": ["layout"],
  "properties": {
    "layout": {
      "type": "string",
      "description": "The exact C++ interface class this layout maps to (e.g., 'iNationalRailLayout').",
      "enum": [
        "iNationalRailLayout",
        "iTflLayout",
        "iBusLayout",
        "iBoardLayout"
      ]
    },
    "boardType": {
      "type": "string",
      "description": "Optional board type hint for the C++ generator.",
      "enum": ["NR", "TFL", "BUS", "TEST"]
    },
    "widgets": {
      "type": "array",
      "description": "Stateful UI components managed by the C++ engine.",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier mapping to a C++ widget instance (e.g., 'header', 'clock', 'services')."
          },
          "type": {
            "type": "string",
            "description": "The exact C++ derived class of this widget. Validating this helps editors autocomplete allowed properties.",
            "enum": [
              "headerWidget",
              "serviceListWidget",
              "scrollingTextWidget",
              "clockWidget",
              "labelWidget",
              "scrollingMessagePoolWidget"
            ]
          },
          "geometry": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "integer", "description": "X-coordinate of the top-left corner" },
              "y": { "type": "integer", "description": "Y-coordinate of the top-left corner" },
              "w": { "type": "integer", "description": "Width. Required for widgets that clip or align within bounds (like header/footer)." },
              "h": { "type": "integer", "description": "Height" }
            }
          },
          "visible": { "type": "boolean", "default": true, "description": "Determines if the widget is drawn." }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "serviceListWidget" } } },
            "then": {
              "properties": {
                "skipRows": { "type": "integer", "description": "Number of rows to discard from the beginning of the data set.", "default": 0 },
                "maxRows": { "type": "integer", "description": "Maximum number of rows to ingest limit (-1 for unbounded).", "default": -1 },
                "columns": {
                  "type": "array",
                  "description": "Column definitions for the Service List widget.",
                  "maxItems": 6,
                  "items": {
                    "type": "object",
                    "properties": {
                      "width": { "type": "integer", "description": "Column width in pixels" },
                      "align": { "type": "integer", "enum": [0, 1, 2], "description": "Text alignment: 0=Left, 1=Center, 2=Right" },
                      "label": { "type": "string", "description": "Optional column header label." }
                    },
                    "required": ["width", "align"]
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "type": { "enum": ["labelWidget", "scrollingTextWidget", "clockWidget", "scrollingMessagePoolWidget"] } } },
            "then": {
              "properties": {
                "font": {
                  "type": "string",
                  "description": "Font string literal defined in the engine.",
                  "enum": [
                    "NatRailSmall9",
                    "NatRailTall12",
                    "NatRailClockSmall7",
                    "NatRailClockLarge9",
                    "Underground10",
                    "UndergroundClock8"
                  ]
                }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "labelWidget" } } },
            "then": {
              "properties": {
                "text": { "type": "string", "description": "Hardcoded text for Label widgets." }
              }
            }
          },
          {
            "if": { "properties": { "type": { "const": "clockWidget" } } },
            "then": {
              "properties": {
                "blink": { "type": "boolean", "description": "Enable blinking colon animation for Clock widgets." }
              }
            }
          }
        ]
      }
    },
    "primitives": {
      "type": "array",
      "description": "Stateless graphics drawn immediately during layout parsing.",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "id": { "type": "string", "description": "Optional identifier for debugging." },
          "type": {
            "type": "string",
            "enum": ["line", "box", "roundedBox", "circle", "triangle", "text"],
            "description": "The type of shape to draw."
          },
          "isFilled": { "type": "boolean", "default": false, "description": "Whether the shape is filled. Applies to box, roundedBox, circle, and triangle." },
          "geometry": {
            "type": "object",
            "properties": {
              "x": { "type": "integer", "description": "X-coordinate for box/text/roundedBox/circle" },
              "y": { "type": "integer", "description": "Y-coordinate for box/text/roundedBox/circle" },
              "w": { "type": "integer", "description": "Width for box/roundedBox" },
              "h": { "type": "integer", "description": "Height for box/roundedBox" },
              "r": { "type": "integer", "description": "Radius for circle/roundedBox" },
              "x1": { "type": "integer", "description": "Start X for lines, X1 for triangle" },
              "y1": { "type": "integer", "description": "Start Y for lines, Y1 for triangle" },
              "x2": { "type": "integer", "description": "End X for lines, X2 for triangle" },
              "y2": { "type": "integer", "description": "End Y for lines, Y2 for triangle" },
              "x0": { "type": "integer", "description": "X0 for triangle" },
              "y0": { "type": "integer", "description": "Y0 for triangle" }
            }
          },
          "text": { "type": "string", "description": "Static string to draw for 'text' primitives." },
          "font": {
             "type": "string",
             "description": "Font to use for 'text' primitives.",
             "enum": [
              "NatRailSmall9",
              "NatRailTall12",
              "NatRailClockSmall7",
              "NatRailClockLarge9",
              "Underground10",
              "UndergroundClock8"
            ]
          }
        }
      }
    }
  }
}
